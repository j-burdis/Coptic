<% content_for :title, "News" %>

<div class="container mx-auto px-4 lg:px-0 pb-16">
  <div class="lg:w-3/5 lg:mx-auto">

    <h1 class="text-3xl font-semibold mb-8">News & Announcements</h1>

    <% if @news_items.present? && @news_items.count > 0 %>
      <div class="space-y-16">
        <% @news_items.each do |news_item| %>
          <%= render partial: 'shared/news_card', locals: { news_item: news_item } %>
        <% end %>
      </div>

      <% if @news_items.total_pages > 1 %>
        <div class="flex justify-center mt-8">
          <%= paginate @news_items %>
        </div>
      <% end %>
    <% else %>
      <p class="text-gray-500">No news items found.</p>
    <% end %>

  </div>
</div>
