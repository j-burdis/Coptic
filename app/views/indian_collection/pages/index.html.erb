<% content_for :title, "Indian Collection" %>

<div>
  <div class="container mx-auto px-2 lg:px-0">
    
    <div class="text-3xl font-semibold pb-8">
      <h1>Indian Collection</h1>
    </div>

    <div class="mb-16">
      <% if @indian_collection_categories.present? %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          
          <div class="block">
            <% if @indian_collection_quote.present? && @indian_collection_quote.text.present? %>
              <p class="text-md text-pretty"><%= @indian_collection_quote.text %></p>
            <% else %>
              <p class="text-md text-pretty">
                Howard Hodgkin's collection of Indian paintings and drawings has been recognised as one of the finest of its kind. 
                It comprises 122 works, including many from the Mughal period (c. 1550–1850). With no interest in academic issues 
                of topography, period or style, it reflects an artist's passion for great art.
              </p>
            <% end %>
          </div>
          
          <% @indian_collection_categories.each do |category_page| %>
            <%= link_to category_page.path, class: "group block hover:text-blue-800" do %>
              <% if category_page.cloudinary_public_id.present? %>
                <div class="aspect-[3/2] overflow-hidden mb-4">
                  <%= image_tag category_page.thumbnail_url, 
                      alt: category_page.title,
                      class: "w-full h-full object-cover" %>
                </div>
              <% end %>
              
              <div>
                <h3 class="text-xl font-semibold mb-2"><%= category_page.title %></h3>
                
                <% if category_page.description.present? %>
                  <p class="text-sm text-yellow-700 group-hover:text-blue-400 text-pretty"><%= category_page.description %></p>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
        
      <% elsif @categories_fallback.present? %>
        <!-- fallback tiles -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          
          <div class="block">
            <% if @indian_collection_quote.present? && @indian_collection_quote.text.present? %>
              <p class="text-md text-pretty"><%= @indian_collection_quote.text %></p>
            <% else %>
              <p class="text-md text-pretty">
                Howard Hodgkin's collection of Indian paintings and drawings has been recognised as one of the finest of its kind. 
                It comprises 122 works, including many from the Mughal period (c. 1550–1850). With no interest in academic issues 
                of topography, period or style, it reflects an artist's passion for great art.
              </p>
            <% end %>
          </div>
          
          <%= link_to indian_collection_gallery_root_path, class: "group block hover:text-blue-800" do %>
            <div>
              <h3 class="text-xl font-semibold mb-2">Gallery</h3>
              <p class="text-sm text-gray-500 group-hover:text-blue-400 text-pretty">
                Howard Hodgkin's Indian collection with links to high-resolution images at the Jameel Centre that allow you to zoom in on details.
              </p>
            </div>
          <% end %>
          
          <%= link_to indian_collection_resources_path, class: "group block hover:text-blue-800" do %>
            <div>
              <h3 class="text-xl font-semibold mb-2">Resources</h3>
              <p class="text-sm text-gray-500 group-hover:text-blue-400 text-pretty">
                Links to films, essays, press reactions, articles and books which explore and contextualise Howard Hodgkin's Indian Collection.
              </p>
            </div>
          <% end %>
          
          <%= link_to indian_collection_exhibition_exhibitions_list_path, class: "group block hover:text-blue-800" do %>
            <div>
              <h3 class="text-xl font-semibold mb-2">Exhibitions</h3>
              <p class="text-sm text-gray-500 group-hover:text-blue-400 text-pretty">
                Hodgkin's Indian Collection has been exhibited around the world.
              </p>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
