<% content_for :title, @artwork.title %>

<div>
  <div class="container mx-auto px-4 lg:px-0 pt-4 pb-16">

    <div class="lg:flex lg:gap-40">      
      <!-- left col - image -->
      <div class="lg:w-3/5 mb-8 lg:mb-0">
        <div class="sticky top-24 lg:w-4/5">
          <% if @artwork.cloudinary_public_id.present? %>
            <%= image_tag @artwork.large_url, 
                alt: @artwork.title,
                class: "w-full h-auto" %>
            <% if @artwork.image_caption.present? %>
              <p class="text-sm text-yellow-700 mt-2"><%= @artwork.image_caption %></p>
            <% end %>
          <% else %>
            <div class="w-full aspect-square flex items-center justify-center" style="background-color: #CCB091;">
              <i class="fa-solid fa-image text-6xl text-gray-300"></i>
            </div>
          <% end %>
        </div>
      </div>

      <!-- right col - details -->
      <div class="lg:w-2/5">
        <!-- breadcrumbs -->
        <nav class="mb-4">
          <ul class="flex items-center text-sm text-gray-600 space-x-2">
            <li><%= link_to "Indian Collection", indian_collection_root_path, class: "hover:text-blue-800" %></li>
            <li><span class="text-gray-400">›</span></li>
            <li><%= link_to "Gallery", indian_collection_gallery_root_path, class: "hover:text-blue-800" %></li>
            <% if @artwork.indian_collection_category.present? %>
              <li><span class="text-gray-400">›</span></li>
              <li>
                <%= link_to @artwork.indian_collection_category.titleize, 
                    indian_collection_category_path_for(@artwork.indian_collection_category), 
                    class: "hover:text-blue-800" %>
              </li>
            <% end %>
          </ul>
        </nav>

        <div class="max-w-xl">
          <h1 class="text-2xl md:text-3xl font-semibold mb-6"><%= @artwork.title %></h1>
          
          <div class="space-y-1 mb-6 text-md md:text-lg text-pretty">
            <% if @artwork.year_range.present? %>
              <p><%= @artwork.year_range %></p>
            <% end %>
            
            <% if @artwork.dimensions.present? %>
              <p><%= @artwork.dimensions %></p>
            <% end %>
            
            <% if @artwork.medium.present? %>
              <p><%= @artwork.medium %></p>
            <% end %>
          </div>

          <% if @artwork.description.present? %>
            <div class="mb-6 text-md md:text-lg text-pretty">
              <%= simple_format(@artwork.description) %>
            </div>
          <% end %>

          <%= render "shared/share_button" %>
        </div>
      </div>
    </div>

  </div>
</div>
