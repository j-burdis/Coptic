<%
  indian_collection ||= false
%>

<div>
  <header class="fixed top-0 left-0 right-0 <%= indian_collection ? 'indian-collection-nav' : 'bg-white' %> p-6 lg:p-8" 
          data-controller="dropdown" 
          style="z-index: 60;">
    <div class="flex items-center justify-between w-full">

      <div class="flex-shrink-0 lg:px-4 sm:pr-4">
        <%= link_to root_path, title: "Howard Hodgkin", rel: "home" do %>
          <%= image_tag "hh-logo.png", alt: "Howard Hodgkin", class: "w-60" %>
          <span class="sr-only">Howard Hodgkin</span>
        <% end %>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center list-none m-0 pl-4 py-0">

        <!-- Gallery Dropdown -->
        <div class="dropdown-container">
          <button class="flex items-center cursor-pointer hover:text-blue-800 transition-opacity px-4 py-3 whitespace-nowrap" data-action="click->dropdown#toggle">
            <span class="text-lg">Gallery</span>
            <%= raw '&nbsp;' %>
            <i class="fa-solid fa-caret-down"></i>
          </button>
          <div id="gallery-dropdown" class="absolute left-0 w-full pb-6 z-50 overflow-hidden transition-[max-height] duration-300 ease-in-out hidden" style="max-height: 0px; background-color: <%= indian_collection ? 'rgba(217, 196, 173, 0.95)' : 'rgba(255, 255, 255, 0.95)' %>;">
            <div data-dropdown-content>
              <%= link_to "Explore", gallery_root_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
              <%= link_to "Paintings", gallery_paintings_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
              <%= link_to "Prints", gallery_prints_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
              <%= link_to "Indian Leaves", gallery_indian_leaves_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
              <%= link_to "Indian Waves", gallery_indian_waves_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
              <%= link_to "Design", gallery_design_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
              <%= link_to "Other", gallery_other_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
              <%= link_to "Missing Works", gallery_missing_works_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
              <%= link_to "All Artworks", gallery_all_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
            </div>  
          </div>
        </div>

        <!-- Resources Dropdown -->
        <div class="dropdown-container">
          <button class="flex items-center cursor-pointer hover:text-blue-800 transition-opacity px-4 py-3 whitespace-nowrap" data-action="click->dropdown#toggle">
            <span class="text-lg">Resources</span>
            <%= raw '&nbsp;' %>
            <i class="fa-solid fa-caret-down"></i>
          </button>
          <div id="resources-dropdown" class="absolute left-0 w-full pb-6 z-50 overflow-hidden transition-[max-height] duration-300 ease-in-out hidden" style="max-height: 0px; background-color: <%= indian_collection ? 'rgba(217, 196, 173, 0.95)' : 'rgba(255, 255, 255, 0.95)' %>;">
            <div data-dropdown-content>
              <%= link_to "Explore", resources_root_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
              <%= link_to "Exhibitions", resources_exhibitions_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
              <%= link_to "Films and Audio", resources_films_and_audio_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
              <%= link_to "Texts", resources_texts_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
              <%= link_to "Publications", resources_publications_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
              <%= link_to "Chronology", resources_chronology_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
              <%= link_to "Collections", resources_collections_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
            </div>
          </div>
        </div>
        
        <!-- Indian Collection Dropdown -->
        <div class="dropdown-container">
          <button class="flex items-center cursor-pointer hover:text-blue-800 transition-opacity px-4 py-3 whitespace-nowrap" data-action="click->dropdown#toggle">
            <span class="text-lg">Indian Collection</span>
            <%= raw '&nbsp;' %>
            <i class="fa-solid fa-caret-down"></i>
          </button>

          <div id="indian-collection-dropdown" class="absolute left-0 w-full pb-6 z-50 overflow-hidden transition-[max-height] duration-300 ease-in-out hidden" style="max-height: 0px; background-color: <%= indian_collection ? 'rgba(217, 196, 173, 0.95)' : 'rgba(255, 255, 255, 0.95)' %>;">
            <div data-dropdown-content>
              <%= link_to "Explore", indian_collection_root_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
              <%= link_to "Artworks", indian_collection_gallery_root_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
              <%= link_to "Resources", indian_collection_resources_path, class: "block px-4 py-1 hover:text-blue-800 transition-colors text-lg" %>
            </div>
          </div>
        </div>
        
        <!-- News Link -->
        <div class="flex items-center">
          <%= link_to "News", news_index_path, class: "hover:text-blue-800 transition-opacity text-lg px-4 py-3 whitespace-nowrap" %>
        </div>
        
        <!-- Search Icon -->
        <button class="flex items-center hover:text-blue-800 transition-opacity cursor-pointer"
                data-action="click->search#open">
          <i class="fa-solid fa-magnifying-glass text-base px-4 py-3"></i>
        </button>

        <!-- Mailing List Icon -->
        <%= link_to subscribe_path, class: "flex items-center hover:text-blue-800 transition-opacity text-xl px-4 py-3" do %>
          <i class="fa-regular fa-envelope"></i>
        <% end %>

        <!-- Instagram Icon -->
        <%= link_to "https://www.instagram.com/howardhodgkin/", target: "_blank", rel: "noopener noreferrer", class: "flex items-center hover:text-blue-800 transition-opacity text-xl px-4 py-3" do %>
          <i class="fa-brands fa-instagram"></i>
        <% end %>
      </nav>

      <!-- Mobile Menu Button -->
      <button class="lg:hidden flex items-center hover:text-blue-800 transition-opacity"
              data-action="click->mobile-menu#toggle">
        <i class="fa-solid fa-bars text-2xl"></i>
      </button>
    </div>

    <!-- Search Overlay -->
    <div data-search-target="overlay"
        class="hidden absolute inset-0 items-center px-6 lg:px-8"
        style="background-color: <%= indian_collection ? 'rgba(217, 196, 173, 0.98)' : 'rgba(244, 244, 244, 0.98)' %>; z-index: 70;">
      
      <!-- logo placeholder to maintain left spacing -->
      <div class="flex-shrink-0 lg:px-4">
        <%= link_to root_path, data: { action: "click->search#close" } do %>
          <%= image_tag "hh-logo.png", alt: "Howard Hodgkin", class: "w-60" %>
        <% end %>
      </div>

      <!-- search input -->
      <div class="flex-1 flex items-center ml-64 mr-16 border border-black">
        <%# <i class="fa-solid fa-magnifying-glass text-gray-400 mr-4"></i> %>
        <input data-search-target="input"
              data-action="input->search#search"
              type="text"
              placeholder="search anything"
              class="flex-1 text-xl font-semibold bg-transparent outline-none py-2 px-4 border-r border-black"
              style="background: white;">
        <button data-action="click->search#close"
                class="px-4 hover:text-blue-800 transition-colors">
          <i class="fa-solid fa-xmark text-xl"></i>
        </button>
      </div>
    </div>

  </header>
</div>
