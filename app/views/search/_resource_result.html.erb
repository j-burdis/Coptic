<%
  use_summary = result.summary.present? && clean_for_preview(result.summary).downcase.include?(query.downcase)
  use_description = !use_summary && result.description.present? && clean_for_preview(result.description).downcase.include?(query.downcase)
  preview_text = if use_summary
    clean_for_preview(result.summary)
  elsif use_description
    clean_for_preview(result.description)
  else
    clean_for_preview(result.summary.presence || result.description.to_s)
  end
%>
<%= link_to result.path, class: "group block" do %>
  <div class="flex flex-col md:flex-row gap-4 md:gap-6 items-start">
    <div class="flex-shrink-0 w-full md:w-40 lg:w-48">
      <% if result.resource_images.any? %>
        <%= image_tag result.resource_images.first.image_url, alt: result.title, class: "w-full h-auto" %>
      <% else %>
        <div class="w-full aspect-[3/2] bg-gray-100 flex items-center justify-center">
          <i class="fa-solid fa-file-lines text-2xl text-gray-300"></i>
        </div>
      <% end %>
    </div>
    <div class="flex-1 space-y-1">
      <p class="text-sm font-semibold text-gray-400 group-hover:text-blue-400">
        <%= result.is_indian_collection? ? 'Indian Collection' : 'Resource' %>
      </p>
      <h2 class="font-semibold text-lg md:text-xl group-hover:text-blue-800"><%= result.title %></h2>
      <% if preview_text.present? %>
        <p class="text-sm md:text-base text-gray-700 group-hover:text-blue-400">
          <% if use_summary %>
            <%= sanitize(highlight_query(preview_text, query), tags: %w(span), attributes: %w(style)) %>
          <% else %>
            <%= search_excerpt(preview_text, query) %>
          <% end %>
        </p>
      <% end %>
    </div>
  </div>
<% end %>
