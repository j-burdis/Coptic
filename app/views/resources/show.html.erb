<div class="bg-white">
  <div class="container mx-auto px-4 lg:px-0 pt-4 pb-16">

    <% if @resource.category == 'texts' %>
      <div class="lg:w-3/5 lg:mx-auto">
        <!-- breadcrumbs -->
        <nav class="text-sm text-gray-500 mb-4">
          <ul class="flex items-center gap-2">
            <li><%= link_to "Resources", resources_path, class: "hover:text-blue-800" %></li>
            <li>></li>
            <li><%= link_to "Texts", resources_texts_path, class: "hover:text-blue-800" %></li>
            <% if @resource.subcategory.present? %>
              <li>></li>
              <li>
                <%= link_to @resource.subcategory.titleize, 
                    resources_texts_subcategory_path(subcategory: @resource.subcategory), 
                    class: "hover:text-blue-800" %>
              </li>
            <% end %>
          </ul>
        </nav>

        <h1 class="text-xl md:text-2xl font-semibold mb-2">
          <%= @resource.title %>, 
          <% if @resource.author.present? %>
            <span class="text-gray-500">by <%= @resource.author %></span>
          <% end %>
        </h1>


        <div class="text-lg mb-6">
          <% if @resource.publisher.present? %>
            <span><%= @resource.publisher %></span>
          <% end %>
          <% if @resource.date.present? || @resource.year.present? %>
            <span class="text-gray-500">
              <% if @resource.publisher.present? %>, <% end %><%= @resource.date_display %>
            </span>
          <% end %>
        </div>

        <% if @resource.external_url.present? %>
          <%= link_to @resource.external_url, target: "_blank", class: "inline-block group font-medium bg-[#F3D8A5] p-2 my-6" do %>
            <span class="group-hover:text-blue-800">View Resource</span>
            <span class="text-gray-500 group-hover:text-blue-400"> ( external link ) <i class="fa-solid fa-arrow-up-right-from-square"></i></span>
          <% end %>
        <% end %>

        <% if @resource.description.present? %>
          <div class="text-pretty prose prose-sm md:prose max-w-none">
            <% if @resource.resource_images.any? %>
              <%= image_tag @resource.resource_images.first.image_url, 
                  alt: @resource.title,
                  class: "float-left w-full md:w-1/2 mr-0 md:mr-6 mb-4" %>
              <% if @resource.resource_images.first.caption.present? %>
                <p class="text-sm text-gray-500 italic mb-4"><%= @resource.resource_images.first.caption %></p>
              <% end %>
            <% end %>
            
            <%= simple_format(@resource.description, class: 'mb-6') %>
          </div>
        <% elsif @resource.summary.present? %>
          <div class="text-pretty prose prose-sm md:prose max-w-none">
            <% if @resource.resource_images.any? %>
              <%= image_tag @resource.resource_images.first.image_url, 
                  alt: @resource.title,
                  class: "float-left w-full md:w-1/2 mr-0 md:mr-6 mb-4" %>
              <% if @resource.resource_images.first.caption.present? %>
                <p class="text-sm text-gray-500 italic mb-4"><%= @resource.resource_images.first.caption %></p>
              <% end %>
            <% end %>
            
            <%= simple_format(@resource.summary, class: 'mb-4') %>
          </div>
        <% end %>

        <%= render "shared/share_button" %>

        <% if @resource.exhibitions.published.any? %>
          <section class="pt-12">
            <h2 class="text-2xl md:text-3xl font-semibold text-center mb-8">
              <span class="border-b-2 border-black pb-1 inline-block">Exhibitions</span>
            </h2>

            <div class="space-y-6">
              <% @resource.exhibitions.published.order(start_date: :desc).each do |exhibition| %>
                <%= link_to exhibition.path, class: "group block" do %>
                  <div class="flex gap-4 md:gap-6 items-start">
                    <div class="flex-shrink-0 w-1/2 md:w-64">
                      <div class="relative bg-white overflow-hidden">
                        <% if exhibition.exhibition_images.any? %>
                          <%= image_tag exhibition.exhibition_images.first.image_url, 
                              alt: exhibition.title,
                              class: "object-cover w-full" %>
                        <% else %>
                          <div class="aspect-[3/2] w-full flex items-center justify-center bg-gray-100">
                            <i class="fa-solid fa-building-columns text-4xl text-gray-300"></i>
                          </div>
                        <% end %>
                      </div>
                    </div>
                    
                    <div class="flex-1 space-y-1">
                      <h3 class="font-semibold text-base md:text-lg">
                        <% if exhibition.venue.present? %>
                          <span class="group-hover:text-blue-800"><%= exhibition.venue %></span>
                          <span class="text-gray-500 group-hover:text-blue-400"> <%= exhibition.title %></span>
                        <% else %>
                          <span class="text-gray-500 group-hover:text-blue-400"><%= exhibition.title %></span>
                        <% end %>
                      </h3>
                      
                      <p class="text-xs md:text-sm">
                        <% if exhibition.location.present? %>
                          <span class="group-hover:text-blue-800"><%= exhibition.location %></span>
                        <% end %>
                        <% if exhibition.start_date.present? %>
                          <span class="text-gray-500 group-hover:text-blue-400">
                            <%= exhibition.year_display %>
                          </span>
                        <% end %>
                      </p>
                    </div>
                  </div>
                <% end %>
              <% end %>
            </div>
          </section>
        <% end %>

      </div>

    <% else %>

      <div class="lg:flex lg:gap-12">
        
        <!-- left column: video/image -->
        <div class="lg:w-2/3 mb-8 lg:mb-0">
          <% if @resource.video_type.present? && @resource.video_id.present? %>
            <!-- embedded video -->
            <div class="aspect-video">
              <% if @resource.video_type == 'youtube' %>
                <iframe 
                  width="100%" 
                  height="100%" 
                  src="https://www.youtube.com/embed/<%= @resource.video_id %>?title=0&byline=0&portrait=0" 
                  frameborder="0" 
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                  allowfullscreen
                  class="w-full h-full">
                </iframe>
              <% elsif @resource.video_type == 'vimeo' %>
                <iframe 
                  src="https://player.vimeo.com/video/<%= @resource.video_id %>?title=0&byline=0&portrait=0" 
                  width="100%" 
                  height="100%" 
                  frameborder="0" 
                  allow="autoplay; fullscreen; picture-in-picture" 
                  allowfullscreen
                  class="w-full h-full">
                </iframe>
              <% end %>
            </div>
          <% else %>
            <!-- image fallback if no video -->
            <div class="lg:w-3/5 mb-8 lg:mb-0">
              <div class="sticky top-24">
                <% if @resource.resource_images.any? %>
                  <%= image_tag @resource.resource_images.first.image_url,
                      alt: @resource.title,
                      class: "w-full h-auto" %>
                  <% if @resource.resource_images.first.caption.present? %>
                    <p class="text-sm text-gray-500 mt-2 italic"><%= @resource.resource_images.first.caption %></p>
                  <% end %>
                <% else %>
                  <div class="w-full aspect-square bg-gray-100 flex items-center justify-center">
                    <i class="fa-solid fa-file-lines text-6xl text-gray-300"></i>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <!-- right column: details -->
        <div class="lg:w-1/3">
          <!-- breadcrumbs -->
          <nav class="text-sm text-gray-500 mb-4">
            <ul class="flex items-center gap-2">
              <li><%= link_to "Resources", resources_path, class: "hover:text-blue-800" %></li>
              <li>></li>
              <% if @resource.category == 'publications' %>
                <li><%= link_to "Publications", resources_publications_path, class: "hover:text-blue-800" %></li>
                <% if @resource.subcategory.present? %>
                  <li>></li>
                  <li>
                    <%= link_to @resource.subcategory.titleize, 
                        resources_publications_subcategory_path(subcategory: @resource.subcategory), 
                        class: "hover:text-blue-800" %>
                  </li>
                <% end %>
              <% elsif @resource.category == 'films_and_audio' %>
                <li><%= link_to "Films & Audio", resources_films_and_audio_path, class: "hover:text-blue-800" %></li>
              <% end %>
            </ul>
          </nav>

          <h1 class="text-2xl md:text-3xl font-semibold mb-4"><%= @resource.title %></h1>

          <% if @resource.author.present? %>
            <p class="text-lg mb-6"><%= @resource.author %></p>
          <% end %>

          <div class="text-lg mb-4">
            <% if @resource.publisher.present? %>
              <span class="text-gray-500">Published by </span>
              <span><%= @resource.publisher %></span>
            <% end %>
          </div>

          <% if @resource.year.present? || @resource.date.present? %>
            <p class="text-lg md:text-xl font-semibold mb-4">
              <%= @resource.date_display %>
            </p>
          <% end %>

          <div class="text-lg mb-4 text-gray-500">
            <% if @resource.isbn.present? %>
              <span>ISBN: <%= @resource.isbn %></span>
            <% end %>
          </div>

          <% if @resource.description.present? %>
            <div class="text-pretty prose prose-sm md:prose max-w-none">
              <%= simple_format(@resource.description, class: 'mb-6') %>
            </div>
          <% elsif @resource.summary.present? %>
            <div class="text-pretty prose prose-sm md:prose max-w-none">
              <%= simple_format(@resource.summary, class: 'mb-6') %>
            </div>
          <% end %>

          <% if @resource.external_url.present? %>
            <%= link_to @resource.external_url, target: "_blank", class: "inline-block group font-medium bg-[#F3D8A5] p-2 my-6" do %>
              <span class="group-hover:text-blue-800">View Resource</span>
              <span class="text-gray-500 group-hover:text-blue-400"> ( external link ) <i class="fa-solid fa-arrow-up-right-from-square"></i></span>
            <% end %>
          <% end %>

          <%= render "shared/share_button" %>
        </div>

      </div>

      <% if @resource.exhibitions.published.any? %>
        <section class="pt-12">
          <h2 class="text-2xl md:text-3xl font-semibold text-center mb-8">
            <span class="border-b-2 border-black pb-1 inline-block">Exhibitions</span>
          </h2>

          <div class="flex flex-wrap justify-center gap-8 mb-8">
            <% @resource.exhibitions.published.order(start_date: :desc).each do |exhibition| %>
              <div class="w-full md:w-[calc(50%-1rem)]">
                <%= link_to exhibition.path, class: "group block" do %>
                  <div class="flex gap-4 md:gap-6 items-start">
                    <div class="flex-shrink-0 w-1/2 md:w-64">
                      <div class="relative bg-white overflow-hidden">
                        <% if exhibition.exhibition_images.any? %>
                          <%= image_tag exhibition.exhibition_images.first.thumbnail_url, 
                              alt: exhibition.title,
                              class: "object-cover w-full" %>
                        <% else %>
                          <div class="aspect-[3/2] w-full flex items-center justify-center bg-gray-100">
                            <i class="fa-solid fa-building-columns text-4xl text-gray-300"></i>
                          </div>
                        <% end %>
                      </div>
                    </div>
                    
                    <div class="flex-1 space-y-1">
                      <h3 class="font-semibold text-base md:text-lg">
                        <% if exhibition.venue.present? %>
                          <span class="group-hover:text-blue-800"><%= exhibition.venue %></span>
                          <span class="text-gray-500 group-hover:text-blue-400"> <%= exhibition.title %></span>
                        <% else %>
                          <span class="text-gray-500 group-hover:text-blue-400"><%= exhibition.title %></span>
                        <% end %>
                      </h3>
                      
                      <p class="text-xs md:text-sm">
                        <% if exhibition.location.present? %>
                          <span class="group-hover:text-blue-800"><%= exhibition.location %></span>
                        <% end %>
                        <% if exhibition.start_date.present? %>
                          <span class="text-gray-500 group-hover:text-blue-400">
                            <%= exhibition.year_display %>
                          </span>
                        <% end %>
                      </p>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>
    <% end %>
  </div>
</div>
