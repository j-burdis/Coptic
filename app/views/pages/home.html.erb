<% content_for :title, "Home" %>

<%# Carousel %>
<% if @carousel_slides.any? %>
  <div class="relative w-full" 
      data-controller="home-carousel">

    <div class="overflow-hidden w-full" style="height: 70vh; min-height: 400px;">
      <div data-home-carousel-target="slides" class="flex h-full">
        <% @carousel_slides.each do |slide| %>
          <div class="flex-shrink-0 w-full h-full relative" data-home-carousel-target="slide">
            <% if slide.cloudinary_public_id.present? %>
              <div class="absolute inset-0 bg-cover bg-center"
                  style="background-image: url('<%= slide.image_url %>');">
              </div>
            <% end %>

            <% if slide.quote_text.present? %>
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent">
              </div>
              <div class="absolute bottom-20 left-0 px-8 md:px-16 text-white max-w-2xl">
                <blockquote>
                  <p class="text-2xl md:text-3xl font-semibold mb-3 leading-snug drop-shadow"><%= slide.quote_text %></p>
                  <% if slide.quote_attribution_name.present? || slide.quote_attribution_date.present? %>
                    <div>
                      <% if slide.quote_attribution_name.present? %>
                        <p class="text-lg md:text-xl"><%= slide.quote_attribution_name %></p>
                      <% end %>
                      <% if slide.quote_attribution_date.present? %>
                        <p class="text-base md:text-lg"><%= slide.quote_attribution_date %></p>
                      <% end %>
                    </div>
                  <% end %>
                </blockquote>
              </div>
            <% end %>

            <%# Caption strip %>
            <div class="absolute bottom-0 left-0 right-0 px-8 md:px-16 py-3"
                style="background-color: rgba(255, 255, 255, 0.7);">
              <%= link_to slide.artwork.path, class: "text-gray-600 text-sm hover:text-blue-800" do %>
                <%= slide.artwork.title %>
                <% if slide.artwork.year_range.present? %>
                  , <%= slide.artwork.year_range %>
                <% end %>
              <% end %>
            </div>

            <%# Full slide link above caption %>
            <%= link_to slide.artwork.path, class: "absolute inset-0", style: "bottom: 44px;" do %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# Dots must be inside the controller element so Stimulus can find them as targets %>
    <% if @carousel_slides.length > 1 %>
      <div class="flex justify-center gap-3 py-4">
        <% @carousel_slides.each_with_index do |_, i| %>
          <button data-action="click->home-carousel#goTo"
                  data-index="<%= i %>"
                  data-home-carousel-target="dot"
                  class="w-4 h-4 rounded-full border-2 border-black transition-all"
                  style="background-color: white;">
          </button>
        <% end %>
      </div>
    <% end %>

  </div>
<% end %>

<%# Intro text %>
<div class="text-center py-12 px-4">
  <p class="text-xl md:text-2xl max-w-3xl mx-auto">
    Sir Gordon Howard Eliot Hodgkin CH CBE (1932 – 2017) was a British painter and printmaker.
  </p>
</div>

<%# Home sections %>
<% @home_sections.each do |section| %>
  <div class="border-t border-gray-200 py-12 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="flex flex-col <%= section.layout == 'image_right' ? 'md:flex-row-reverse' : 'md:flex-row' %> gap-8 md:gap-12 items-start">

        <% if section.image_cloudinary_public_id.present? || section.video_url.present? %>
          <div class="w-full md:w-1/2 flex-shrink-0">
            <% if section.video_url.present? %>
              <div class="relative cursor-pointer group" data-controller="video-modal"
                   data-video-modal-url-value="<%= section.video_url %>">
                <% if section.image_cloudinary_public_id.present? %>
                  <%= image_tag section.image_url, alt: section.title, class: "w-full h-auto" %>
                <% end %>
                <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/30 transition-colors"
                     data-action="click->video-modal#open">
                  <div class="w-16 h-16 rounded-full bg-white/80 flex items-center justify-center">
                    <i class="fa-solid fa-play text-2xl ml-1"></i>
                  </div>
                </div>
              </div>
            <% else %>
              <%= image_tag section.image_url, alt: section.title, class: "w-full h-auto" %>
            <% end %>
            <% if section.image_caption.present? %>
              <p class="text-sm text-gray-500 mt-2"><%= section.image_caption %></p>
            <% end %>
          </div>
        <% end %>

        <div class="flex-1">
          <% if section.title.present? %>
            <h2 class="text-2xl md:text-3xl font-semibold mb-4"><%= section.title %></h2>
          <% end %>

          <% if section.description.present? %>
            <div class="text-base md:text-lg leading-relaxed mb-6">
              <%= simple_format(section.description, {}, sanitize: false) %>
            </div>
          <% end %>

          <% if section.link_url.present? && section.link_text.present? %>
            <%= link_to section.link_text, section.link_url,
                class: "text-base hover:text-blue-800" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<%# Video modal %>
<div id="video-modal" class="hidden fixed inset-0 bg-black/80 flex items-center justify-center"
     style="z-index: 100;"
     data-action="click->video-modal#closeOnBackdrop">
  <div class="relative w-full max-w-4xl px-4">
    <button class="absolute -top-10 right-4 text-white text-3xl hover:opacity-70"
            data-action="click->video-modal#close">
      ×
    </button>
    <div id="video-modal-content" class="relative aspect-video">
    </div>
  </div>
</div>
