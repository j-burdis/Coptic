<div class="lg:flex lg:gap-12">
  <div class="lg:w-2/3 mb-8 lg:mb-0">
    <%= render 'resources/media', resource: resource %>
  </div>

  <div class="lg:w-1/3">
    <%= render 'resources/breadcrumbs', resource: resource %>
    <%= render 'resources/header', resource: resource, centered: false %>
    <%= render "shared/share_button" %>
  </div>
</div>

<%= render 'resources/related_exhibitions', resource: resource, layout: 'grid' if resource.exhibitions.published.any? %>
