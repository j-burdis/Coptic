<div class="border-b border-gray-200 pb-6 mb-6 last:border-0">
  <div>
    <h3 class="text-2xl md:text-3xl font-semibold text-gray-500 mb-3"><%= resource.year_display %></h3>
  </div>

  <!-- mobile layout with float -->
  <% if resource.resource_images.any? %>
    <div class="md:hidden text-pretty text-lg leading-relaxed">
      <div class="float-right ml-4 mb-2 w-1/2">
        <%= image_tag resource.resource_images.first.image_url,
            alt: resource.year_display,
            class: "w-full object-cover" %>
        <% if resource.resource_images.first.caption.present? %>
          <p class="text-xs text-gray-500 mt-2"><%= resource.resource_images.first.caption %></p>
        <% end %>
      </div>
      <% if resource.description.present? %>
        <%= simple_format(resource.description) %>
      <% end %>
    </div>
  <% end %>

  <!-- desktop layout - exact original -->
  <div class="<%= resource.resource_images.any? ? 'hidden md:flex' : 'flex' %> gap-4 md:gap-6 items-start">
    <div class="<%= resource.resource_images.any? ? 'w-1/2' : 'w-full' %>">
      <% if resource.description.present? %>
        <div class="text-pretty text-lg md:text-xl leading-relaxed max-w-none">
          <%= simple_format(resource.description) %>
        </div>
      <% end %>
    </div>

    <% if resource.resource_images.any? %>
      <div class="flex-shrink-0 w-1/2 md:w-auto">
        <%= image_tag resource.resource_images.first.image_url,
            alt: resource.year_display,
            class: "w-full md:w-auto md:max-w-full object-cover" %>
        <% if resource.resource_images.first.caption.present? %>
          <p class="text-xs md:text-sm text-gray-500 mt-2 text-pretty"><%= resource.resource_images.first.caption %></p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>