<% content_for :title, @artwork.title %>

<div class="bg-white">
  <div class="container mx-auto px-4 lg:px-0 pt-4 pb-16">

    <div class="lg:flex lg:gap-40">      
      <!-- left col - image -->
      <div class="lg:w-3/5 mb-8 lg:mb-0">
        <div class="sticky top-24 lg:w-4/5">
          <% if @artwork.cloudinary_public_id.present? %>
            <%= image_tag @artwork.large_url, 
                alt: @artwork.title,
                class: "w-full h-auto" %>
          <% else %>
            <div class="w-full aspect-square bg-gray-100 flex items-center justify-center">
              <i class="fa-solid fa-image text-6xl text-gray-300"></i>
            </div>
          <% end %>
        </div>
      </div>

      <!-- right col - details -->
      <div class="lg:w-2/5">
        <!-- breadcrumbs -->
        <nav class="mb-4">
          <ul class="flex items-center text-md text-gray-600 space-x-2">
            <li><%= link_to "Gallery", gallery_root_path, class: "hover:text-blue-800" %></li>
            <% if @artwork.category.present? %>
              <li><span class="text-gray-400">›</span></li>
              <li><%= link_to @artwork.category.titleize, category_path_for(@artwork.category), class: "hover:text-blue-800" %></li>
              <% if @artwork.category == 'design' && @artwork.subcategory.present? %>
                <li><span class="text-gray-400">›</span></li>
                <li>
                  <%= link_to Artwork::DESIGN_SUBCATEGORIES.find { |slug, name| slug == @artwork.subcategory }&.last || @artwork.subcategory.titleize, 
                      gallery_design_subcategory_path(subcategory: @artwork.subcategory), 
                      class: "hover:text-blue-800" %>
                </li>
              <% end %>
            <% end %>
          </ul>
        </nav>

        <div class="max-w-xl">
          <h1 class="text-2xl md:text-3xl font-semibold mb-6"><%= @artwork.title %></h1>
          
          <div class="space-y-2 mb-6 text-pretty">
            <% if @artwork.year.present? %>
              <div class="text-xl md:text-2xl font-semibold">
                <p><%= @artwork.year_range %></p>
              </div>
            <% end %>
            
            <% if @artwork.dimensions.present? %>
              <p class="text-lg md:text-xl"><%= @artwork.dimensions %></p>
            <% end %>
            
            <% if @artwork.medium.present? %>
              <p class="text-lg md:text-xl"><%= @artwork.medium %></p>
            <% end %>
          </div>

          <!-- description -->
          <% if @artwork.description.present? %>
            <div class="mb-6 text-lg md:text-xl text-pretty">
              <%= simple_format(@artwork.description) %>
            </div>
          <% end %>

          <%= render 'artwork_collections', artwork: @artwork if @artwork.collections.any? %>

          <%= render "shared/share_button" %>
        </div>
      </div>
    </div>

    <%= render 'artwork_exhibitions', artwork: @artwork if @artwork.exhibitions.any? %>

  </div>
</div>