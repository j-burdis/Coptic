<%
  indian_collection ||= false
  image_url ||= nil
  text_color = indian_collection ? 'text-yellow-700' : 'text-gray-500'

  pinterest_url = "https://pinterest.com/pin/create/button/?url=#{CGI.escape(request.original_url)}"
  pinterest_url += "&media=#{CGI.escape(image_url)}" if image_url.present?
%>

<div data-controller="share">
  <button 
    data-action="click->share#toggle"
    class="flex items-center gap-2 text-sm font-semibold <%= text_color %> hover:text-blue-800 transition-colors"
  >
    Share
    <i class="fa-solid fa-share-nodes"></i>
  </button>

  <div 
    data-share-target="menu"
    class="overflow-hidden transition-all duration-300 ease-in-out mt-2"
    style="max-height: 0"
  >
    <div class="flex gap-6">
      <a href="https://twitter.com/intent/tweet?url=<%= CGI.escape(request.original_url) %>" 
         target="_blank"
         class="text-sm  hover:text-blue-800">
        <i class="fa-brands fa-x-twitter"></i> Twitter
      </a>
      <a href="https://www.facebook.com/sharer/sharer.php?u=<%= CGI.escape(request.original_url) %>"
         target="_blank"
         class="text-sm  hover:text-blue-800">
        <i class="fa-brands fa-facebook"></i> Facebook
      </a>
      <a href="<%= pinterest_url %>"
         target="_blank"
         class="text-sm hover:text-blue-800">
        <i class="fa-brands fa-pinterest"></i> Pinterest
      </a>
    </div>
  </div>
</div>