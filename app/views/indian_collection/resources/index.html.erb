<% content_for :title, "Indian Resources" %>

<div>
  <div class="container mx-auto px-2 lg:px-0">
    
    <div class="text-xl md:text-3xl font-semibold pb-8">
      <h2>Resources (Indian Collection)</h2>
    </div>

    <div class="flex-1">
      <% if @resources.present? && @resources.count > 0 %>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 mb-8" style="grid-auto-rows: auto;">
          <% @resources.each do |resource| %>
            <%= render partial: 'shared/resource_card', locals: { resource: resource, indian_collection: true } %>
          <% end %>
        </div>
        
        <% if @resources.total_pages > 1 %>
          <div class="flex justify-center">
            <%= paginate @resources %>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-16">
          <i class="fa-solid fa-file-lines text-6xl text-gray-300 mb-4"></i>
          <p class="text-xl text-gray-600">No resources found</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
