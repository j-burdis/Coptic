<div class="lg:w-3/5 lg:mx-auto">
  <%= render 'resources/breadcrumbs', resource: resource %>
  
  <%= render 'resources/header', resource: resource, centered: true %>
  
  <% if resource.description.present? || resource.summary.present? %>
    <%
      content = resource.description.presence || resource.summary
      images = resource.resource_images.order(:position)
      has_placeholders = content.match?(/\[image:\d+\]/)
      parts = content.split(/(\[image:\d+\])/)
    %>

    <div class="text-pretty text-base leading-relaxed max-w-none">
      <% if !has_placeholders && images.first.present? %>
        <div class="float-left w-full md:w-1/2 mr-0 md:mr-6 mb-4">
          <%= image_tag images.first.image_url, alt: resource.title, class: "w-full" %>
          <% if images.first.caption.present? %>
            <p class="caption text-xs text-gray-500 mt-2"><%= render_caption(images.first.caption) %></p>
          <% end %>
        </div>
      <% end %>

      <% parts.each_with_index do |part, i| %>
        <% if part.match?(/\[image:(\d+)\]/) %>
          <%
            index = part.match(/\[image:(\d+)\]/)[1].to_i - 1
            img = images[index]
          %>
          <% if img.present? %>
            <% if i == 0 || (i == 1 && parts[0].strip.blank?) %>
              <div class="float-left w-full md:w-1/2 mr-0 md:mr-6 mb-4">
                <%= image_tag img.image_url, alt: resource.title, class: "w-full" %>
                <% if img.caption.present? %>
                  <p class="caption text-xs text-gray-500 mt-2"><%= render_caption(img.caption) %></p>
                <% end %>
              </div>
            <% else %>
              <div class="clear-both w-full md:w-2/3 my-8 mx-auto">
                <%= image_tag img.image_url, alt: resource.title, class: "w-full" %>
                <% if img.caption.present? %>
                  <p class="caption text-xs text-gray-500 mt-2"><%= render_caption(img.caption) %></p>
                <% end %>
              </div>
            <% end %>
          <% end %>
        <% elsif part.strip.present? %>
          <%= simple_format(part, { class: 'mb-4' }, sanitize: false ) %>
        <% end %>
      <% end %>
    </div>
  <% end %>
  
  <%= render "shared/share_button", image_url: resource.image_url %>
  
  <%= render 'resources/related_exhibitions', resource: resource, layout: 'list' if resource.exhibitions.published.any? %>
</div>
