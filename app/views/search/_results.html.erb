<% if query.length >= 3 %>
  <% if total_count > 0 %>
    <p class="text-xl font-semibold pb-16">
      Result<%= total_count == 1 ? '' : 's' %> for "<%= query %>"
      <span class="text-gray-500">(<%= total_count %>)</span>
    </p>

    <div class="space-y-20 pb-16">
      <% results.each do |result| %>
        <% case result %>
        <% when Artwork %>
          <%= render 'search/artwork_result', result: result, query: query %>
        <% when Resource %>
          <%= render 'search/resource_result', result: result, query: query %>
        <% when NewsItem %>
          <%= render 'search/news_result', result: result, query: query %>
        <% when Exhibition %>
          <%= render 'search/exhibition_result', result: result, query: query %>
        <% when Collection %>
          <%= render 'search/collection_result', result: result, query: query %>
        <% end %>
      <% end %>
    </div>

    <% if total_pages > 1 %>
      <nav class="flex items-center justify-center gap-1 my-8 pb-16" role="navigation" aria-label="pager">
        <% if current_page > 1 %>
          <span class="prev">
            <button data-action="click->search#goToPage" data-page="<%= current_page - 1 %>"
                    class="px-3 py-1 text-base hover:text-blue-800 transition-colors">«</button>
          </span>
        <% end %>

        <%
          window_start = [current_page - 2, 1].max
          window_end = [current_page + 2, total_pages].min
          window_start = [window_end - 4, 1].max if window_end - window_start < 4
        %>

        <% if window_start > 1 %>
          <span class="page">
            <button data-action="click->search#goToPage" data-page="1"
                    class="px-3 py-1 text-sm text-black hover:text-blue-800 transition-colors">1</button>
          </span>
          <% if window_start > 2 %>
            <span class="px-2 py-1 text-base cursor-default select-none">&hellip;</span>
          <% end %>
        <% end %>

        <% (window_start..window_end).each do |page| %>
          <span class="page">
            <% if page == current_page %>
              <span class="px-3 py-1 text-base border border-black"><%= page %></span>
            <% else %>
              <button data-action="click->search#goToPage" data-page="<%= page %>"
                      class="px-3 py-1 text-sm text-black hover:text-blue-800 transition-colors"><%= page %></button>
            <% end %>
          </span>
        <% end %>

        <% if window_end < total_pages %>
          <% if window_end < total_pages - 1 %>
            <span class="px-2 py-1 text-base cursor-default select-none">&hellip;</span>
          <% end %>
          <span class="page">
            <button data-action="click->search#goToPage" data-page="<%= total_pages %>"
                    class="px-3 py-1 text-sm text-black hover:text-blue-800 transition-colors"><%= total_pages %></button>
          </span>
        <% end %>

        <% if current_page < total_pages %>
          <span class="next">
            <button data-action="click->search#goToPage" data-page="<%= current_page + 1 %>"
                    class="px-3 py-1 text-base hover:text-blue-800 transition-colors">»</button>
          </span>
        <% end %>
      </nav>
    <% end %>

  <% else %>
    <p class="text-gray-500 text-center">No results found for "<%= query %>"</p>
  <% end %>
<% end %>
