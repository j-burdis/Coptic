<% if query.length >= 3 %>
  <% if total_count > 0 %>
    <p class="text-sm text-gray-500 mb-6">
      <%= total_count %> result<%= total_count == 1 ? '' : 's' %> for "<%= query %>"
    </p>

    <div class="space-y-20 pb-16">

      <% artworks.each do |artwork| %>
        <%= link_to artwork.path, class: "group block" do %>
          <div class="flex flex-col md:flex-row gap-4 md:gap-6 items-start">
            <div class="flex-shrink-0 w-full md:w-40 lg:w-48">
              <% if artwork.cloudinary_public_id.present? %>
                <%= image_tag artwork.large_url, alt: artwork.title, class: "w-full h-auto" %>
              <% else %>
                <div class="w-full aspect-[3/2] bg-gray-100 flex items-center justify-center">
                  <i class="fa-solid fa-image text-2xl text-gray-300"></i>
                </div>
              <% end %>
            </div>
            <div class="flex-1 space-y-1">
              <p class="text-sm font-semibold text-gray-400 group-hover:text-blue-400"><%= artwork.is_indian_collection? ? 'Indian Collection' : 'Artwork' %></p>
              <h2 class="font-semibold text-lg md:text-xl group-hover:text-blue-800"><%= artwork.title %></h2>
              <% if artwork.description.present? %>
                <p class="text-sm md:text-base font-semibold text-gray-700 group-hover:text-blue-400">
                  <%= search_excerpt(artwork.description, query) %>
                </p>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>

      <% resources.each do |resource| %>
        <%= link_to resource.path, class: "group block" do %>
          <div class="flex flex-col md:flex-row gap-4 md:gap-6 items-start">
            <div class="flex-shrink-0 w-full md:w-40 lg:w-48">
              <% if resource.resource_images.any? %>
                <%= image_tag resource.resource_images.first.image_url, alt: resource.title, class: "w-full h-auto" %>
              <% else %>
                <div class="w-full aspect-[3/2] bg-gray-100 flex items-center justify-center">
                  <i class="fa-solid fa-file-lines text-2xl text-gray-300"></i>
                </div>
              <% end %>
            </div>
            <div class="flex-1 space-y-1">
              <p class="text-sm font-semibold text-gray-400 group-hover:text-blue-400"><%= resource.is_indian_collection? ? 'Indian Collection' : 'Resource' %></p>
              <h2 class="font-semibold text-lg md:text-xl group-hover:text-blue-800"><%= resource.title %></h2>
              <% preview = resource.summary.presence || resource.description %>
              <% if preview.present? %>
                <p class="text-sm md:text-base font-semibold text-gray-700 group-hover:text-blue-400">
                  <%= search_excerpt(preview, query) %>
                </p>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>

      <% news_items.each do |news_item| %>
        <%= link_to news_item.path, class: "group block" do %>
          <div class="flex flex-col md:flex-row gap-4 md:gap-6 items-start">
            <div class="flex-shrink-0 w-full md:w-40 lg:w-48">
              <% if news_item.cloudinary_public_id.present? %>
                <%= image_tag news_item.large_url, alt: news_item.title, class: "w-full h-auto" %>
              <% else %>
                <div class="w-full aspect-[3/2] bg-gray-100 flex items-center justify-center">
                  <i class="fa-solid fa-newspaper text-2xl text-gray-300"></i>
                </div>
              <% end %>
            </div>
            <div class="flex-1 space-y-1">
              <p class="text-sm font-semibold text-gray-400 group-hover:text-blue-400">News</p>
              <h2 class="font-semibold text-lg md:text-xl group-hover:text-blue-800"><%= news_item.title %></h2>
              <% preview = news_item.excerpt.presence || news_item.content %>
              <% if preview.present? %>
                <p class="text-sm md:text-base font-semibold text-gray-700 group-hover:text-blue-400">
                  <%= search_excerpt(preview, query) %>
                </p>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>

      <% exhibitions.each do |exhibition| %>
        <%= link_to exhibition_path(exhibition.slug), class: "group block" do %>
          <div class="flex flex-col md:flex-row gap-4 md:gap-6 items-start">
            <div class="flex-shrink-0 w-full md:w-40 lg:w-48">
              <% if exhibition.exhibition_images.any? %>
                <%= image_tag exhibition.exhibition_images.first.image_url, alt: exhibition.title, class: "w-full h-auto" %>
              <% else %>
                <div class="w-full aspect-[3/2] bg-gray-100 flex items-center justify-center">
                  <i class="fa-solid fa-palette text-2xl text-gray-300"></i>
                </div>
              <% end %>
            </div>
            <div class="flex-1 space-y-1">
              <p class="text-sm font-semibold text-gray-400 group-hover:text-blue-400">Exhibition</p>
              <h2 class="font-semibold text-lg md:text-xl group-hover:text-blue-800"><%= exhibition.title %></h2>
              <% if exhibition.description.present? %>
                <p class="text-sm md:text-base font-semibold text-gray-700 group-hover:text-blue-400">
                  <%= search_excerpt(exhibition.description, query) %>
                </p>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>

      <% collections.each do |collection| %>
        <%= link_to collection_path(collection.slug), class: "group block" do %>
          <div class="flex flex-col md:flex-row gap-4 md:gap-6 items-start">
            <div class="flex-shrink-0 w-full md:w-40 lg:w-48">
              <% if collection.cloudinary_public_id.present? %>
                <%= image_tag collection.large_url, alt: collection.name, class: "w-full h-auto" %>
              <% else %>
                <div class="w-full aspect-[3/2] bg-gray-100 flex items-center justify-center">
                  <i class="fa-solid fa-building-columns text-2xl text-gray-300"></i>
                </div>
              <% end %>
            </div>
            <div class="flex-1 space-y-1">
              <p class="text-sm font-semibold text-gray-400 group-hover:text-blue-400">Collection</p>
              <h2 class="font-semibold text-lg md:text-xl group-hover:text-blue-800"><%= collection.name %></h2>
              <% if collection.description.present? %>
                <p class="text-sm md:text-base font-semibold text-gray-700 group-hover:text-blue-400">
                  <%= search_excerpt(collection.description, query) %>
                </p>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>

    </div>

  <% else %>
    <p class="text-gray-500 text-center">No results found for "<%= query %>"</p>
  <% end %>
<% end %>
