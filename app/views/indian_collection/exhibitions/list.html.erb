<% content_for :title, "Exhibitions List" %>

<div>
  <div class="container mx-auto px-4 lg:px-0 py-2">
    <div class="lg:w-7/12 lg:mx-auto">
      
      <% list = IndianCollectionExhibitionList.published.first %>
      <% if list&.updated_at.present? %>
        <p class="text-sm text-yellow-700"><%= list.updated_at.strftime("#{list.updated_at.day.ordinalize} %B %Y") %></p>
      <% end %>
      <h1 class="text-2xl font-semibold mb-4">Exhibitions List</h1>

      <% if @decades.present? %>
        <% @decades.each do |decade, exhibitions| %>
          <div class="mb-8">
            <h2 class="text-base font-semibold mb-3"><%= decade %></h2>
            <ul class="space-y-2">
              <% exhibitions.each do |exhibition| %>
                <li class="text-base pl-4 border-l-2 border-yellow-700 text-pretty">
                    <% parts = exhibition.split(',', 2) %>
                    <em><%= parts[0] %></em><% if parts[1] %>,<%= parts[1] %><% end %>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
      <% else %>
        <p class="text-gray-600">No exhibition list available.</p>
      <% end %>

    </div>
  </div>
</div>