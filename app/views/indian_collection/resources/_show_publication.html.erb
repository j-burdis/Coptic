<div class="lg:w-3/5 lg:mx-auto">

  <% if resource.resource_images.any? %>
    <div class="w-full mb-6">
      <%= image_tag resource.resource_images.first.image_url,
          alt: resource.title,
          class: "w-full h-auto" %>
      <% if resource.resource_images.first.caption.present? %>
        <p class="text-sm text-yellow-700 mt-2"><%= resource.resource_images.first.caption %></p>
      <% end %>
    </div>
  <% end %>

  <nav class="mb-4">
    <ul class="flex items-center text-base text-yellow-700 space-x-2">
      <li><%= link_to "Indian Collection", indian_collection_root_path, class: "text-yellow-700 hover:text-blue-800" %></li>
      <li><span class="text-yellow-700">›</span></li>
      <li><%= link_to "Resources", indian_collection_resources_path, class: "text-yellow-700 hover:text-blue-800" %></li>
    </ul>
  </nav>

  <%= render 'resources/header', resource: resource, centered: true, indian_collection: true %>

  <% if resource.description.present? || resource.summary.present? %>
    <div class="text-pretty text-lg md:text-xl max-w-none">
      <%
        content = resource.description.presence || resource.summary
        images = resource.resource_images.order(:position)
        has_placeholders = content.match?(/\[image:\d+\]/)
        parts = content.split(/(\[image:\d+\])/)
      %>

      <% parts.each do |part| %>
        <% if part.match?(/\[image:(\d+)\]/) %>
          <%
            index = part.match(/\[image:(\d+)\]/)[1].to_i - 1
            img = images[index]
          %>
          <% if img.present? %>
            <div class="clear-both w-full md:w-2/3 my-8 mx-auto">
              <%= image_tag img.image_url, alt: resource.title, class: "w-full" %>
              <% if img.caption.present? %>
                <p class="text-sm text-yellow-700 mt-2"><%= img.caption %></p>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <%= simple_format(part, class: 'mb-4') %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%= render "shared/share_button", indian_collection: true %>
</div>