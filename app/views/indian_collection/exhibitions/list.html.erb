<% content_for :title, "Exhibitions List" %>

<div class="bg-white">
  <div class="container mx-auto px-4 lg:px-0 py-8">
    <div class="lg:w-3/5 lg:mx-auto">
      
      <h1 class="text-3xl font-semibold mb-8">Exhibitions List</h1>

      <% if @exhibition_list.present? %>
        <div class="prose prose-sm md:prose max-w-none exhibition-list-content">
          <%= sanitize @exhibition_list.content, 
              tags: %w(p b i em strong ul li h1 h2 h3 span),
              attributes: %w(style aria-level) %>
        </div>
      <% else %>
        <p class="text-gray-600">No exhibition list available.</p>
      <% end %>
      
    </div>
  </div>
</div>
